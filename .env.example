# Do not hand-edit keys here — copy the live file from Node:
#   Copy-Item "..\\Signing server\\.env" .env -Force
# Browser-tab ingest/broadcast is intentionally NOT implemented in the Go server.

HOST=0.0.0.0
PORT=18085

WS_CONNECT_TOKEN=your-shared-ws-token
INGEST_TOKEN_SECRET=your-ingest-secret
# INGEST_TOKEN_TTL_MS=900000
# ALLOW_CALL_EVENTS_WITHOUT_TOKEN=false

DATABASE_URL=
# SUPABASE_DATABASE_URL=
# Match Node signing server; Supabase session pooler (5432) rejects >15 total clients.
PG_POOL_MAX=10
PG_POOL_MIN=0

# AUDIT_DASHBOARD_URL=http://localhost:3000
# AUDIT_SUPERADMIN_SERVICE_SECRET=

# --- Production concurrency (many clients + multi-stream audit wall) ---
MAX_CONNECTIONS=4000
MAX_PER_IP=2000
MAX_ADMIN_VIEWER_TARGETS=64
MAX_VIEWERS_PER_CLIENT=12
SIGNALING_RATE_CAPACITY=800
SIGNALING_RATE_REFILL_PER_SEC=400

HEARTBEAT_CHECK_INTERVAL_MS=8000
CLIENT_HEARTBEAT_TIMEOUT_MS=90000
WS_PING_INTERVAL_MS=25000
# Cooldown only when two *live* sockets fight for the same deviceId (reconnect after OTA is allowed).
DEVICE_TAKEOVER_COOLDOWN_MS=3000

ENABLE_TASKBAR_TELEMETRY=true
# ENABLE_TASKBAR_INGEST_LOGS=false

# Streaming policy (P2P first → TURN → optional SFU)
ICE_PHASE_ONE_MS=5000
STREAM_TURN_VIEWER_THRESHOLD=2
STREAM_TURN_ADMIN_TARGETS_THRESHOLD=4
STREAM_SFU_VIEWER_THRESHOLD=3
STREAM_SFU_ADMIN_TARGETS_THRESHOLD=8
ENABLE_CLOUDFLARE_SFU=false
# AnyWhere-SFU app (Realtime Connection API — separate from TURN key token below)
# CLOUDFLARE_REALTIME_APP_ID=
# CLOUDFLARE_REALTIME_API_TOKEN=
# Secondary Cloudflare account (failover lane 2 — SFU + TURN)
# CLOUDFLARE_REALTIME_APP_ID_2=
# CLOUDFLARE_REALTIME_API_TOKEN_2=
# MEDIA_PROVIDER_COOLDOWN_MS=45000
# MEDIA_PROVIDER_PROBE_INTERVAL_MS=90000

# TURN / ICE (optional — same as Node .env.turn)
# ICE_TURN_SOURCE=cloudflare
# CLOUDFLARE_TURN_KEY_ID=
# CLOUDFLARE_TURN_KEY_API_TOKEN=
# CLOUDFLARE_TURN_KEY_ID_2=
# CLOUDFLARE_TURN_KEY_API_TOKEN_2=
# TURN_STUN_URL=stun:...
# TURN_UDP_URL=turn:...
# TURN_SECRET=

# Full DB wipe on startup (dev only). Default: soft reconcile — end sessions, clear stale socket_id, keep roster.
# SIGNALING_WIPE_DB=1

# SEED_SUPER_ADMIN=true
# BOOTSTRAP_ADMIN_PASSWORD=
